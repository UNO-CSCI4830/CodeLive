PORT=5000

# Supabase — get values from Supabase Dashboard → Settings → API
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic — get your key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key

# Code execution mode:
# - direct: execute in this process
# - proxy: forward /api/run/* to RUNNER_BASE_URL
RUN_EXECUTION_MODE=direct
RUNNER_BASE_URL=http://localhost:5001
RUNNER_SHARED_TOKEN=replace_with_strong_shared_token
RUNNER_REQUIRE_TOKEN=false
RUNNER_REQUEST_TIMEOUT_MS=30000
RUN_RATE_LIMIT_ENABLED=true
RUN_RATE_LIMIT_WINDOW_MS=60000
RUN_RATE_LIMIT_MAX=30
RUNNER_MAX_CONCURRENT_EXECUTIONS=4
